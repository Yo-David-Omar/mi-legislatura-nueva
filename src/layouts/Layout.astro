---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} - Legislatura de Tucumán</title>
  </head>
  <body class="bg-gray-50">
    <!-- Navbar -->
    <nav class="bg-blue-900 text-white p-4 shadow-md">
      <div class="container mx-auto flex justify-between items-center">
        <h1 class="text-xl font-bold">LEGISLATURA DE TUCUMÁN</h1>
        <div class="hidden md:flex gap-4">
          <a href="/" class="hover:text-blue-200 transition">Inicio</a>
          <a href="/periodos" class="hover:text-blue-200 transition">Períodos</a>
        </div>
      </div>
    </nav>

    <!-- Contenido principal -->
    <main class="container mx-auto p-6 min-h-screen">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white p-6 text-center mt-8">
      <p>&copy; {new Date().getFullYear()} Honorable Legislatura de Tucumán</p>
    </footer>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;
</style>