---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">
  
  <!-- Sección central con el Libro -->
  <div class="flex flex-col items-center justify-center space-y-8">
    
    <!-- Imagen del Libro Real -->
    <div class="w-full max-w-3xl mx-auto">
      <img 
        src="/libros/libro-taquigrafos.jpg" 
        alt="Libro de Taquígrafos - Poder Legislativo" 
        class="w-full h-auto rounded-lg shadow-2xl"
      >
    </div>

    <!-- Botones de acceso rápido -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 w-full max-w-3xl mt-8">
      <a href="/periodos" class="bg-white hover:bg-blue-50 p-6 rounded-lg shadow-lg border-2 border-blue-900 text-center hover:shadow-xl transition">
        <i class="bi bi-calendar-check text-4xl block mb-3 text-blue-900"></i>
        <span class="text-sm font-bold text-gray-800">Períodos</span>
      </a>
      <a href="#" class="bg-white hover:bg-blue-50 p-6 rounded-lg shadow-lg border-2 border-blue-900 text-center hover:shadow-xl transition">
        <i class="bi bi-journal-text text-4xl block mb-3 text-blue-900"></i>
        <span class="text-sm font-bold text-gray-800">Diario de Sesiones</span>
      </a>
      <a href="#" class="bg-white hover:bg-blue-50 p-6 rounded-lg shadow-lg border-2 border-blue-900 text-center hover:shadow-xl transition">
        <i class="bi bi-people text-4xl block mb-3 text-blue-900"></i>
        <span class="text-sm font-bold text-gray-800">Legisladores</span>
      </a>
      <a href="#" class="bg-white hover:bg-blue-50 p-6 rounded-lg shadow-lg border-2 border-blue-900 text-center hover:shadow-xl transition">
        <i class="bi bi-file-earmark-text text-4xl block mb-3 text-blue-900"></i>
        <span class="text-sm font-bold text-gray-800">Leyes</span>
      </a>
    </div>

  </div>
</Layout>