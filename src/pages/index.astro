---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const periodos = await getCollection('periodos');
const periodosOrdenados = periodos.sort((a, b) => b.data.numero - a.data.numero);
---

<Layout title="Inicio">
  <div class="text-center mb-12">
    <h1 class="text-4xl md:text-5xl font-bold text-blue-900 mb-4">
      Períodos Legislativos
    </h1>
    <p class="text-gray-600 text-lg">
      Honorable Legislatura de Tucumán
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {periodosOrdenados.map((periodo) => (
      <a 
        href={`/periodos/${periodo.id}`}
        class="bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition border-l-4 border-blue-900"
      >
        <h2 class="text-2xl font-bold text-gray-800">
          {periodo.data.titulo}
        </h2>
        <p class="text-gray-600 mt-2">{periodo.data.anio}</p>
        <div class="mt-4 text-blue-600">
          Ver detalles →
        </div>
      </a>
    ))}
  </div>
</Layout>