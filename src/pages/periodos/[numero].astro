---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const periodos = await getCollection('periodos');
  return periodos.map((periodo) => ({
    params: { numero: periodo.id },
    props: { periodo },
  }));
}

const { periodo } = Astro.props;
---

<Layout title={periodo.data.titulo}>
  <div class="mb-8">
    <a href="/" class="text-blue-600 hover:underline">← Volver al inicio</a>
    <h1 class="text-4xl font-bold text-blue-900 mt-4">
      {periodo.data.titulo}
    </h1>
    <p class="text-gray-600 text-lg">{periodo.data.anio}</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {periodo.data.secciones.map((seccion) => (
      <a 
        href={seccion.url}
        class="bg-white p-6 rounded-lg shadow-md hover:shadow-xl transition border-l-4 border-blue-900"
      >
        <h2 class="text-xl font-bold text-gray-800 mb-2">
          {seccion.nombre}
        </h2>
        <p class="text-blue-600 text-sm">Ver contenido →</p>
      </a>
    ))}
  </div>

  <article class="bg-white p-6 rounded-lg shadow-md mt-8 prose max-w-none">
    <div set:html={periodo.body} />
  </article>
</Layout>