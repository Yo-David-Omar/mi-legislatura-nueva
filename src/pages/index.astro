---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const periodos = await getCollection('periodos');
const periodosOrdenados = periodos.sort((a, b) => b.data.numero - a.data.numero);
---

<Layout title="Inicio">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-blue-50 to-white py-12 md:py-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-6xl font-bold text-blue-900 mb-4">
        Períodos Legislativos
      </h1>
      <p class="text-gray-600 text-lg md:text-xl max-w-2xl mx-auto">
        Accede al archivo histórico de sesiones, leyes y autoridades de la Legislatura de Tucumán
      </p>
    </div>
  </section>

  <!-- Grid de Períodos -->
  <section class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {periodosOrdenados.map((periodo) => (
        <a 
          href={`/periodos/${periodo.id}`}
          class="group bg-white p-6 rounded-xl shadow-md hover:shadow-2xl transition-all duration-300 border-t-4 border-blue-900 hover:border-blue-600 hover:-translate-y-1"
        >
          <div class="flex items-start justify-between mb-4">
            <div class="bg-blue-100 p-3 rounded-lg group-hover:bg-blue-900 transition-colors">
              <i class="bi bi-calendar-range text-2xl text-blue-900 group-hover:text-white"></i>
            </div>
            <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded">
              {periodo.data.anio}
            </span>
          </div>
          
          <h2 class="text-2xl font-bold text-gray-800 group-hover:text-blue-900 transition-colors">
            {periodo.data.titulo}
          </h2>
          
          {periodo.data.descripcion && (
            <p class="text-gray-600 mt-2 text-sm line-clamp-2">
              {periodo.data.descripcion}
            </p>
          )}
          
          <div class="mt-4 flex items-center text-blue-600 group-hover:text-blue-900 font-medium">
            <span>Ver detalles</span>
            <i class="bi bi-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>