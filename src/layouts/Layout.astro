---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <title>{title} - Legislatura de Tucumán</title>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col">
    
    <!-- HEADER INSTITUCIONAL -->
    <header class="bg-gradient-to-r from-blue-900 to-blue-700 text-white py-6 shadow-lg">
      <div class="container mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-4">
          <i class="bi bi-bank text-4xl md:text-5xl"></i>
          <div>
            <h1 class="text-xl md:text-2xl font-bold tracking-wide">HONORABLE LEGISLATURA</h1>
            <p class="text-blue-200 text-sm md:text-base">de la Provincia de Tucumán</p>
          </div>
        </div>
        <div class="text-center md:text-right">
          <p class="text-xs text-blue-200">República Argentina</p>
        </div>
      </div>
    </header>

    <!-- NAVBAR RESPONSIVE -->
    <nav class="bg-white shadow-md sticky top-0 z-40" x-data="{ open: false }">
      <div class="container mx-auto px-4">
        <div class="flex justify-between items-center py-3">
          <a href="/" class="text-blue-900 font-bold text-lg hover:text-blue-700 transition">
            <i class="bi bi-house-door mr-2"></i>Inicio
          </a>
          
          <!-- Botón hamburguesa (solo visible en móvil) -->
          <button 
            @click="open = !open" 
            class="md:hidden text-blue-900 focus:outline-none"
            aria-label="Menú"
          >
            <i class="bi bi-list text-3xl"></i>
          </button>

          <!-- Menú de escritorio (visible en desktop) -->
          <div class="hidden md:flex gap-6 items-center">
            <a href="/" class="text-gray-700 hover:text-blue-900 transition font-medium">
              <i class="bi bi-calendar-range mr-1"></i>Períodos
            </a>
            <a href="#" class="text-gray-700 hover:text-blue-900 transition font-medium">
              <i class="bi bi-people mr-1"></i>Legisladores
            </a>
            <a href="#" class="text-gray-700 hover:text-blue-900 transition font-medium">
              <i class="bi bi-diagram-3 mr-1"></i>Comisiones
            </a>
            <a href="#" class="text-gray-700 hover:text-blue-900 transition font-medium">
              <i class="bi bi-info-circle mr-1"></i>Información
            </a>
          </div>
        </div>

        <!-- Menú móvil (se despliega al hacer clic) -->
        <div x-show="open" x-transition class="md:hidden pb-4">
          <div class="flex flex-col gap-2">
            <a href="/" class="text-gray-700 hover:bg-blue-50 hover:text-blue-900 py-2 px-3 rounded transition">
              <i class="bi bi-calendar-range mr-2"></i>Períodos
            </a>
            <a href="#" class="text-gray-700 hover:bg-blue-50 hover:text-blue-900 py-2 px-3 rounded transition">
              <i class="bi bi-people mr-2"></i>Legisladores
            </a>
            <a href="#" class="text-gray-700 hover:bg-blue-50 hover:text-blue-900 py-2 px-3 rounded transition">
              <i class="bi bi-diagram-3 mr-2"></i>Comisiones
            </a>
            <a href="#" class="text-gray-700 hover:bg-blue-50 hover:text-blue-900 py-2 px-3 rounded transition">
              <i class="bi bi-info-circle mr-2"></i>Información
            </a>
          </div>
        </div>
      </div>
    </nav>

    <!-- CONTENIDO PRINCIPAL -->
    <main class="flex-grow">
      <slot />
    </main>
    <!-- BOTÓN FLOTANTE DE WHATSAPP -->
    <a 
      href="https://wa.me/5493816114185?text=Hola,%20quiero%20más%20información" 
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-6 right-6 z-50 bg-green-500 hover:bg-green-600 text-white p-4 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-110 group"
      aria-label="Contactar por WhatsApp"
    >
      <i class="bi bi-whatsapp text-3xl"></i>
      <span class="absolute right-full mr-3 top-1/2 -translate-y-1/2 bg-gray-800 text-white text-sm px-3 py-2 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
        ¡Escríbenos!
      </span>
    </a>
    <!-- FOOTER -->
    <footer class="bg-gray-800 text-white py-8 mt-12">
      <div class="container mx-auto px-4 text-center">
        <div class="flex justify-center items-center gap-2 mb-4">
          <i class="bi bi-bank text-2xl"></i>
          <h3 class="text-lg font-bold">Legislatura de Tucumán</h3>
        </div>
        <p class="text-gray-400 text-sm">
          &copy; {new Date().getFullYear()} Honorable Legislatura de la Provincia de Tucumán
        </p>
        <p class="text-gray-500 text-xs mt-2">
          San Miguel de Tucumán, Argentina
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;
</style>