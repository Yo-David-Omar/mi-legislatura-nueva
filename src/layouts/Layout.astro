---
interface Props {
  title: string;
}

const { title } = Astro.props;

const navLinks = [
  { text: "INICIO", url: "/" },
  { text: "AUTORIDADES", url: "#" },
  { text: "MANDATOS Y SEC. ELECTORALES", url: "#" },
  { text: "INDICE TEMÁTICO", url: "#" },
  { text: "ACTIVIDAD PARLAMENTARIA", url: "#" },
  { text: "COMISIONES", url: "#" },
  { text: "DIARIO DE SESIONES", url: "/diario-sesiones" },
  { text: "CUADRO DE LEYES", url: "#" },
];

const periodosMenu = [
  { 
    id: "120", 
    label: "Período 120", 
    items: ["Autoridades", "Diario de Sesiones", "Índice Temático", "Cuadro de Leyes"] 
  },
  { 
    id: "119", 
    label: "Período 119", 
    items: ["Autoridades", "Diario de Sesiones", "Cuadro de Leyes"] 
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&display=swap" rel="stylesheet">
    <title>{title} - Legislatura de Tucumán</title>
  </head>
  
  <body class="bg-gray-100 min-h-screen" style="font-family: 'Merriweather', serif;">
    
    <!-- 1. BARRA DE NAVEGACIÓN SUPERIOR (ROJA) -->
    <nav class="bg-red-900 text-white shadow-lg">
      <div class="container mx-auto px-4">
        <!-- Menú Horizontal Desktop -->
        <ul class="hidden md:flex flex-wrap justify-center gap-6 py-3 text-sm font-bold">
          {navLinks.map((link) => (
            <li>
              <a href={link.url} class="hover:text-yellow-300 transition tracking-wide">
                {link.text}
              </a>
            </li>
          ))}
        </ul>
        
        <!-- Menú Hamburguesa Móvil -->
        <div x-data="{ open: false }" class="md:hidden flex justify-center py-3">
          <button @click="open = !open" class="text-white border-2 border-white px-4 py-2 rounded font-bold">
            <i class="bi bi-list mr-2"></i>MENÚ
          </button>
          <ul x-show="open" @click.outside="open = false" class="absolute top-full left-0 w-full bg-red-950 flex flex-col p-4 gap-2 text-center shadow-xl z-50">
            {navLinks.map((link) => (
              <li>
                <a href={link.url} class="block py-3 border-b border-white/20 hover:bg-white/10 font-bold">
                  {link.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </nav>

    <!-- 2. HEADER INSTITUCIONAL -->
    <header class="bg-white/95 backdrop-blur-sm shadow-md py-6">
      <div class="container mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4">
        
        <!-- Logo/Escudo -->
        <div class="mb-4 md:mb-0">
          <img src="/imagenesescudo/escudo.png" alt="Escudo Legislatura" class="h-20 w-auto">
        </div>

        <!-- Título -->
        <div class="flex-grow text-center md:text-left">
          <h1 class="text-2xl md:text-3xl font-black text-gray-800 tracking-wider uppercase">
            HONORABLE LEGISLATURA DE TUCUMÁN
          </h1>
        </div>

        <!-- Reloj -->
        <div class="bg-gray-100 px-6 py-3 rounded-lg border-2 border-gray-300 shadow-inner">
          <span id="clock" class="font-mono text-2xl font-bold text-red-900">00:00:00</span>
        </div>
      </div>
    </header>

    <!-- 3. SUB-BARRA (DIRECCIÓN DE TAQUÍGRAFOS) -->
    <div class="bg-red-950 text-white py-3 text-center shadow-md">
      <h2 class="text-base md:text-lg font-bold tracking-widest uppercase">
        <i class="bi bi-book-half mr-2"></i> DIRECCIÓN DE TAQUÍGRAFOS
      </h2>
    </div>

    <!-- 4. ESTRUCTURA PRINCIPAL (SIDEBAR + CONTENIDO) -->
    <div class="container mx-auto px-4 py-8 min-h-screen flex flex-col md:flex-row gap-8">
      
      <!-- SIDEBAR IZQUIERDO (DROPDOWNS DE PERÍODOS) -->
      <aside class="w-full md:w-72 flex-shrink-0 space-y-4">
        {periodosMenu.map((periodo) => (
          <div x-data="{ open: false }" class="group">
            <!-- Botón del Período -->
            <button 
              @click="open = !open"
              class="w-full text-left bg-blue-900 hover:bg-blue-800 text-white py-4 px-5 rounded-lg shadow-lg font-bold flex justify-between items-center transition-all"
            >
              <span class="text-lg">{periodo.label}</span>
              <i class="bi bi-chevron-down transition-transform duration-300" :class="{'rotate-180': open}"></i>
            </button>
            
            <!-- Menú Desplegable -->
            <ul x-show="open" x-transition class="mt-2 bg-white rounded-lg shadow-xl overflow-hidden border-2 border-blue-900/20">
              {periodo.items.map((item) => (
                <li>
                  <a href="#" class="block px-5 py-3 text-sm text-gray-700 hover:bg-blue-100 hover:text-blue-900 transition border-b border-gray-100 last:border-0 font-medium">
                    {item}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <!-- Botón "Qué es un período" -->
        <a href="#" class="block w-full text-center bg-blue-100 hover:bg-blue-200 text-blue-900 py-3 px-4 rounded-lg text-sm font-bold mt-4 transition border-2 border-blue-300">
          ¿QUÉ ES UN PERÍODO LEGISLATIVO?
        </a>
      </aside>

      <!-- CONTENIDO PRINCIPAL -->
      <main class="flex-grow w-full">
        <slot />
      </main>
      
    </div>

    <!-- 5. BOTÓN FLOTANTE WHATSAPP -->
    <a 
      href="https://wa.me/5493811234567" 
      target="_blank"
      class="fixed bottom-6 right-6 z-50 bg-green-500 hover:bg-green-600 text-white px-5 py-4 rounded-full shadow-xl hover:scale-110 transition-all duration-300 flex items-center gap-2 group"
    >
      <i class="bi bi-whatsapp text-3xl"></i>
      <span class="max-w-0 overflow-hidden group-hover:max-w-xs transition-all duration-500 whitespace-nowrap font-bold">
        WhatsApp
      </span>
    </a>

    <!-- Script para el Reloj -->
    <script>
      function updateClock() {
        const now = new Date();
        const timeString = now.toLocaleTimeString('es-AR');
        const clockElement = document.getElementById('clock');
        if (clockElement) clockElement.textContent = timeString;
      }
      setInterval(updateClock, 1000);
      updateClock();
    </script>
  </body>
</html>